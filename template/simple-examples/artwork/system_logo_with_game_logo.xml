<?xml version="1.0" encoding="UTF-8"?>
<artwork>
    <meta author="Boxart Buddy" notes="Right aligned game logo and system logo on a transparent background"></meta>
    <output type="cover" width="640" height="480">
        <layer resource="system-logos/{{ 'logo-type'|trans({}, 'general', locale) }}/{{ 'logo'|trans({}, 'logo', locale) }}"
               x="-50" y="80" width="150" align="right" valign="top">
        </layer>
        <layer resource="wheel" width="150" align="right" valign="bottom" x="-50" y="-80">
            <stroke width="4" red="255" green="255" blue="255"/>
        </layer>
    </output>

    <output type="screenshot" width="515" height="275">
        <layer resource="screenshot" height="275" align="center" valign="middle"/>
    </output>
</artwork>