<?xml version="1.0" encoding="UTF-8"?>
<artwork>
    <meta author="Boxart Buddy"
          notes="Large central game logo with screenshot on side, covers the whole screen, desaturated to match LCD style themes"></meta>

    <output type="cover" width="640" height="480">
        <layer resource="screenshot" width="640" align="center" valign="top">
            <opacity value="95"/>
            <colorize hue="180" saturation="-100"/>
            <balance red="22" green="56" blue="48"/>

            <mask file="large-wheel-central-with-screenshot.png" width="640" height="480"/>
        </layer>

        <layer resource="wheel" width="200" align="center" valign="middle">
            <stroke width="2" red="0" green="0" blue="0"/>
            <shadow distance="8" softness="5" opacity="50"/>
            <colorize hue="180" saturation="-100"/>
            <balance red="22" green="56" blue="48"/>
        </layer>

    </output>

    <output type="screenshot" width="515" height="275">
        <layer resource="screenshot" height="275" align="center" valign="middle">
            <colorize hue="180" saturation="-100"/>
            <balance red="22" green="56" blue="48"/>
        </layer>
    </output>
</artwork>