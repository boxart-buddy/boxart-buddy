<?xml version="1.0" encoding="UTF-8"?>
<artwork>
    <output type="cover" width="640" height="480">

        <!--        <layer width="640" height="480">-->
        <!--            <layer resource="inner-frame.png" x="218" align="left" valign="center"></layer>-->
        <!--        </layer>-->

        <layer resource="system-logos/{{ 'logo-type'|trans({}, 'general', locale)|default('dark-white') }}/{{ 'logo'|trans({}, 'logo', locale) }}"
               width="320" align="center" valign="middle">
            <stroke width="{{ 'logo-stroke-width'|trans({}, 'general', locale)|default('0') }}"
                    color="{{ locale|trans({}, 'logo-stroke', locale)|default('#FFFFFF') }}"/>
            <shadow distance="8" softness="5" opacity="50"/>
        </layer>

    </output>
</artwork>
